# Example environment for apigee-hybrid-aks-setup (copy to .env or apigee-hybrid.env and fill in).
# Do not commit real credentials. See docs/setup-script-environment.md for the full variable list.

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
# Set to 1 for automation/CI when every required variable below is set.
# APIGEE_SETUP_NONINTERACTIVE=1

APIGEE_NAMESPACE=apigee

# Charts baked into the image; override only if you re-pull or use a custom layout.
# APIGEE_HELM_CHARTS_HOME=/workspace/apigee-hybrid/helm-charts
# CHART_VERSION=
# CERT_MANAGER_VERSION=v1.19.2

# -----------------------------------------------------------------------------
# GCP / Apigee org
# -----------------------------------------------------------------------------
PROJECT_ID=YOUR_GCP_PROJECT_ID
ORG_NAME=YOUR_GCP_PROJECT_ID

# -----------------------------------------------------------------------------
# Azure AKS
# -----------------------------------------------------------------------------
CLUSTER_NAME=YOUR_AKS_CLUSTER_NAME
CLUSTER_LOCATION=YOUR_AZURE_REGION
AZURE_RESOURCE_GROUP=YOUR_AZURE_RESOURCE_GROUP
# AZURE_SUBSCRIPTION=

# -----------------------------------------------------------------------------
# Install profile and auth
# -----------------------------------------------------------------------------
INSTALL_PROFILE=non-prod
# AUTH_MODE=secrets
# AUTH_MODE_CHOICE=1

# -----------------------------------------------------------------------------
# Overrides wizard (often required in non-interactive runs)
# -----------------------------------------------------------------------------
APIGEE_ENVIRONMENT_NAME=YOUR_APIGEE_ENVIRONMENT_NAME
# INSTANCE_ID=
# ANALYTICS_REGION=
# INGRESS_GATEWAY_NAME=ingw1
# VIRTUALHOST_NAME=
# HELM_ENV_RELEASE=

# -----------------------------------------------------------------------------
# TLS (step tls) — set when you automate that step
# -----------------------------------------------------------------------------
# TLS_DOMAIN=your.example.com
# TLS_ENV_GROUP=your-slug

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# OVERRIDES_YAML_PATH=
# OVERRIDES_WIZARD_MODE=g
# DRY_RUN_HELM=n
